# ============================================================================
# RGCNFormer Mobile Web - Backend Configuration
# ============================================================================
# Copy this file to .env and update with your local settings

# ----------------------------------------------------------------------------
# Redis Configuration
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ----------------------------------------------------------------------------
# Celery Configuration
# ----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3000

# ----------------------------------------------------------------------------
# Model Configuration
# ----------------------------------------------------------------------------
MODEL_CHECKPOINT_PATH=epoch_040.pt
MODEL_CONFIG_PATH=json/human.json
MODEL_DEVICE=cpu
MODEL_TARGET_LENGTH=1001

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=False

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT='%(asctime)s - %(name)s - %(levelname)s - [%(funcName)s:%(lineno)d] - %(message)s'
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# ----------------------------------------------------------------------------
# Cache Configuration
# ----------------------------------------------------------------------------
REDIS_CACHE_TTL=3600

# ----------------------------------------------------------------------------
# Classification Thresholds (12-class)
# ----------------------------------------------------------------------------
THRESHOLD_12_AM=0.510
THRESHOLD_12_ATOL=0.400
THRESHOLD_12_CM=0.690
THRESHOLD_12_GM=0.710
THRESHOLD_12_TM=0.350
THRESHOLD_12_Y=0.150
THRESHOLD_12_AC4C=0.120
THRESHOLD_12_M1A=0.380
THRESHOLD_12_M5C=0.350
THRESHOLD_12_M6A=0.260
THRESHOLD_12_M6AM=0.570
THRESHOLD_12_M7G=0.130

# ----------------------------------------------------------------------------
# Classification Thresholds (4-class)
# ----------------------------------------------------------------------------
THRESHOLD_4_A=0.980
THRESHOLD_4_C=0.270
THRESHOLD_4_G=0.050
THRESHOLD_4_U=0.050

# ----------------------------------------------------------------------------
# Default Top-K for Attention Visualization
# ----------------------------------------------------------------------------
DEFAULT_TOP_K=3

# ----------------------------------------------------------------------------
# WeChat Mini Program Configuration
# ----------------------------------------------------------------------------
# Get these from WeChat Mini Program admin console
WX_APPID=your_wechat_appid_here
WX_SECRET=your_wechat_secret_here
